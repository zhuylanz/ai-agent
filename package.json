{
  "name": "@zhuylanz/ai-agent",
  "version": "1.0.0",
  "description": "Standalone AI Agent library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "validate": "node validate.js",
    "prepublishOnly": "npm run clean && npm run build && npm run validate",
    "demo:postgres": "NODE_NO_WARNINGS=1 dotenv -- ts-node examples/postgres-demo.ts",
    "demo:basic": "NODE_NO_WARNINGS=1 dotenv -- ts-node examples/basic-usage.ts",
    "demo:openai": "NODE_NO_WARNINGS=1 dotenv -- ts-node examples/openai-examples.ts",
    "demo:anthropic": "NODE_NO_WARNINGS=1 dotenv -- ts-node examples/anthropic-examples.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "langchain",
    "tools",
    "llm",
    "chat"
  ],
  "author": "Huy Lan",
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@types/pg": "^8.15.2",
    "langchain": "^0.3.0",
    "lodash": "^4.17.21",
    "mysql2": "^3.14.1",
    "pg": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.6.0",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.14.195",
    "@types/node": "^18.17.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.6"
  },
  "peerDependencies": {
    "@langchain/anthropic": "^0.3.0",
    "@langchain/openai": "^0.3.0"
  }
}
