{
  "name": "@lapage/ai-agent",
  "version": "1.0.2",
  "description": "Standalone AI Agent library built on LangChain with MCP tool calling, memory, and vector knowledge base support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "validate": "node validate.js",
    "prepublishOnly": "npm run clean && npm run build && npm run validate",
    "demo:postgres": "NODE_NO_WARNINGS=1 dotenv -- ts-node examples/postgres-demo.ts",
    "demo:basic": "NODE_NO_WARNINGS=1 dotenv -- ts-node examples/basic-usage.ts",
    "demo:openai": "NODE_NO_WARNINGS=1 dotenv -- ts-node examples/openai-examples.ts",
    "demo:anthropic": "NODE_NO_WARNINGS=1 dotenv -- ts-node examples/anthropic-examples.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "langchain",
    "tools",
    "llm",
    "chat"
  ],
  "author": "Huy Lan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhuylanz/AIAgent.git"
  },
  "bugs": {
    "url": "https://github.com/zhuylanz/AIAgent/issues"
  },
  "homepage": "https://github.com/zhuylanz/AIAgent#readme",
  "dependencies": {
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/json-schema": "^7.0.15",
    "langchain": "^0.3.0",
    "lodash": "^4.17.21",
    "pg": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.6.0",
    "@langchain/anthropic": "^0.3.34",
    "@langchain/openai": "^0.3.17",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.14.195",
    "@types/node": "^18.17.0",
    "@types/pg": "^8.15.2",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6"
  },
  "peerDependencies": {
    "@langchain/anthropic": "^0.3.34",
    "@langchain/openai": "^0.3.17"
  },
  "peerDependenciesMeta": {
    "@langchain/anthropic": {
      "optional": true
    },
    "@langchain/openai": {
      "optional": true
    }
  }
}
